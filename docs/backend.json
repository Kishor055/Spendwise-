
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User profile with basic settings and preferences.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "currency": { "type": "string", "default": "INR" },
        "monthlyBudget": { "type": "number", "default": 50000 },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboarded": { "type": "boolean", "default": false }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Financial transaction records.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Food", "Shopping", "Travel", "Recharge", "Electricity", "Fuel", "Rent", "EMI", "Entertainment", "Healthcare", "Salary", "Freelance", "Gift", "Investment", "Other"] },
        "note": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "receiptUrl": { "type": "string" }
      },
      "required": ["id", "userId", "type", "amount", "category", "date", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "type": "object",
      "description": "Financial savings goals.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number", "default": 0 },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "targetAmount", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "type": "object",
      "description": "Recurring subscription services.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "category": { "type": "string" },
        "nextBillingDate": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean", "default": true }
      },
      "required": ["id", "userId", "name", "amount", "billingCycle"]
    }
  },
  "auth": {
    "providers": ["password", "google", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transactions."
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "User financial goals."
    },
    "/users/{userId}/subscriptions/{subscriptionId}": {
      "schema": { "$ref": "#/entities/Subscription" },
      "description": "User recurring subscriptions."
    }
  }
}
